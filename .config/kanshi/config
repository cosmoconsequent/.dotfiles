output "LG Electronics LG ULTRAGEAR 306NTDV4P106" {
  mode 3440x1440
  position 0,0
  scale 1
  alias $LG34
}

output "Lenovo Group Limited N160JCA-GT1" {
  mode 1920x1080
  position 3440,480
  scale 1.25
  alias $INTERNAL
}

profile docked {
  output $LG34 enable
  output $INTERNAL enable
}

profile undocked {
  output $INTERNAL enable
}
