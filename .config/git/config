[init]
	defaultBranch = main
[core]
	autocrlf = input
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
	syntax-theme = kanagawa
[diff]
	algorithm = histogram
[merge]
	conflictStyle = zdiff3
[rerere]
	enabled = true
[credential]
	helper = cache
	helper = !type pass-git-helper >/dev/null 2>&1 && pass-git-helper $@
	helper = !test -x $(git --exec-path)/git-credential-osxkeychain && $(git --exec-path)/git-credential-osxkeychain $@
[include]
	path = ~/.config/git/config.local
[credential "https://github.com"]
	helper = 
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !gh auth git-credential
[credential "https://gitlab.com"]
	helper = 
	helper = !glab auth git-credential
